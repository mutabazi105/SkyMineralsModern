@page
@model SkyMineralsModern.Pages.ProductionModel
@{
    ViewData["Title"] = "Production Management";
    
    var role = HttpContext.Session.GetString("Role");
    if (role != "Administrator" && role != "Production")
    {
        HttpContext.Response.Redirect("/Login");
    }
}

<h1>Production Management</h1>
<hr />

<div style="background: #f4f4f4; padding: 20px; margin-bottom: 30px;">
    <h3>Record Production</h3>
    <form method="post">
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px;">
            <div><label>Mineral:</label><select asp-for="NewProduction.Minls_code" style="width: 100%;"><option value="">Select</option>@foreach (var m in Model.MineralsList){<option value="@m.Minls_code">@m.Type</option>}</select></div>
            <div><label>Staff:</label><select asp-for="NewProduction.Staff_id" style="width: 100%;"><option value="">Select</option>@foreach (var s in Model.StaffList){<option value="@s.Staff_id">@s.Fname @s.Lname</option>}</select></div>
            <div><label>Quantity (kg):</label><input type="number" step="0.01" asp-for="NewProduction.Quantity_mined" style="width: 100%;" /></div>
            <div><label>Status:</label><select asp-for="NewProduction.Status" style="width: 100%;"><option>untagged</option><option>tagged</option></select></div>
        </div>
        <button type="submit" style="background: #28a745; color: white; padding: 8px 15px; border: none;">Record Production</button>
    </form>
</div>

<h3>Production Records</h3>
<table style="width: 100%; border-collapse: collapse;">
    <thead><tr style="background: #465c71; color: white;"><th>Operation Code</th><th>Mineral</th><th>Staff</th><th>Quantity</th><th>Date</th><th>Status</th></tr></thead>
    <tbody>
        @foreach (var prod in Model.ProductionList)
        {
            <tr><td>@prod.Op_code</td><td>@prod.MineralType</td><td>@prod.StaffName</td><td>@prod.Quantity_mined</td><td>@prod.Issue_date.ToString("yyyy-MM-dd")</td><td>@prod.Status</td></tr>
        }
    </tbody>
</table>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div style="background: #d4edda; color: #155724; padding: 10px; margin-top: 15px;">@Model.Message</div>
}