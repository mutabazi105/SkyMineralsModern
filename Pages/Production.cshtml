@page
@model SkyMineralsModern.Pages.ProductionModel
@{
    ViewData["Title"] = "Production Management";
    
    var role = HttpContext.Session.GetString("Role");
    if (role != "Administrator" && role != "Production")
    {
        HttpContext.Response.Redirect("/Login");
    }
}

<h1 style="color: #2c3e50;">Production Management</h1>
<hr />

<!-- Add New Production Record -->
<div style="background: #f4f4f4; padding: 20px; margin-bottom: 30px; border-radius: 8px;">
    <h3>Record Mineral Production</h3>
    <form method="post">
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px;">
            <div>
                <label>Mineral Type:</label>
                <select asp-for="NewProduction.Minls_code" style="width: 100%; padding: 8px;" required>
                    <option value="">Select Mineral</option>
                    @foreach (var mineral in Model.MineralsList)
                    {
                        <option value="@mineral.Minls_code">@mineral.Type</option>
                    }
                </select>
            </div>
            <div>
                <label>Staff Member:</label>
                <select asp-for="NewProduction.Staff_id" style="width: 100%; padding: 8px;" required>
                    <option value="">Select Staff</option>
                    @foreach (var staff in Model.StaffList)
                    {
                        <option value="@staff.Staff_id">@staff.Fname @staff.Lname</option>
                    }
                </select>
            </div>
            <div>
                <label>Quantity Mined (kg):</label>
                <input type="number" step="0.01" asp-for="NewProduction.Quantity_mined" style="width: 100%; padding: 8px;" required />
            </div>
            <div>
                <label>Status:</label>
                <select asp-for="NewProduction.Status" style="width: 100%; padding: 8px;">
                    <option value="untagged">Untagged</option>
                    <option value="tagged">Tagged</option>
                </select>
            </div>
        </div>
        <button type="submit" style="margin-top: 15px; padding: 10px 20px; background: #28a745; color: white; border: none; border-radius: 5px;">Record Production</button>
    </form>
</div>

<!-- Production Records List -->
<h3>Production Records</h3>
<table style="width: 100%; border-collapse: collapse;">
    <thead>
        <tr style="background: #2c3e50; color: white;">
            <th style="padding: 10px;">Operation Code</th>
            <th style="padding: 10px;">Mineral</th>
            <th style="padding: 10px;">Staff</th>
            <th style="padding: 10px;">Quantity (kg)</th>
            <th style="padding: 10px;">Date</th>
            <th style="padding: 10px;">Status</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.ProductionList != null && Model.ProductionList.Any())
        {
            @foreach (var prod in Model.ProductionList)
            {
                <tr style="border-bottom: 1px solid #ddd;">
                    <td style="padding: 10px;">@prod.Op_code</td>
                    <td style="padding: 10px;">@prod.MineralType</td>
                    <td style="padding: 10px;">@prod.StaffName</td>
                    <td style="padding: 10px;">@prod.Quantity_mined</td>
                    <td style="padding: 10px;">@prod.Issue_date.ToString("yyyy-MM-dd")</td>
                    <td style="padding: 10px;">@prod.Status</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" style="padding: 20px; text-align: center;">No production records found.</td>
            </tr>
        }
    </tbody>
</table>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div style="margin-top: 20px; padding: 10px; background: @(Model.Message.Contains("success") ? "#d4edda" : "#f8d7da"); color: @(Model.Message.Contains("success") ? "#155724" : "#721c24"); border-radius: 5px;">
        @Model.Message
    </div>
}