@page
@model SkyMineralsModern.Pages.MineralsModel
@{
    ViewData["Title"] = "Minerals Management";
    
    var role = HttpContext.Session.GetString("Role");
    if (role != "Administrator" && role != "Manager")
    {
        HttpContext.Response.Redirect("/Login");
    }
}

<h1>Minerals Management</h1>
<hr />

<div style="background: #f4f4f4; padding: 20px; margin-bottom: 30px;">
    <h3>Add New Mineral</h3>
    <form method="post">
        <input type="text" asp-for="NewMineral.Type" placeholder="Mineral Type" style="padding: 8px; width: 300px;" />
        <button type="submit" style="background: #28a745; color: white; padding: 8px 15px; border: none;">Add Mineral</button>
    </form>
</div>

<h3>Existing Minerals</h3>
<table style="width: 100%; border-collapse: collapse;">
    <thead><tr style="background: #465c71; color: white;"><th>ID</th><th>Mineral Type</th><th>Actions</th></tr></thead>
    <tbody>
        @foreach (var mineral in Model.MineralsList)
        {
            <tr><td>@mineral.Minls_code</td><td>@mineral.Type</td>
            <td><form method="post" asp-page-handler="Delete"><input type="hidden" name="id" value="@mineral.Minls_code" /><button type="submit" style="background: #dc3545; color: white; border: none; padding: 5px 10px;">Delete</button></form></td></tr>
        }
    </tbody>
</table>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div style="background: #d4edda; color: #155724; padding: 10px; margin-top: 15px;">@Model.Message</div>
}