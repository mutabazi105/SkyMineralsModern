@page
@model SkyMineralsModern.Pages.MineralsModel
@{
    ViewData["Title"] = "Minerals Management";
    
    var role = HttpContext.Session.GetString("Role");
    if (role != "Administrator" && role != "Manager")
    {
        HttpContext.Response.Redirect("/Login");
    }
}

<h1 style="color: #2c3e50;">Minerals Management</h1>
<hr />

<!-- Add New Mineral Form -->
<div style="background: #f4f4f4; padding: 20px; margin-bottom: 30px; border-radius: 8px;">
    <h3>Add New Mineral Type</h3>
    <form method="post">
        <div style="display: flex; gap: 15px; align-items: flex-end;">
            <div style="flex: 1;">
                <label>Mineral Type:</label>
                <input type="text" asp-for="NewMineral.Type" style="width: 100%; padding: 8px;" required />
            </div>
            <div>
                <button type="submit" style="padding: 8px 20px; background: #28a745; color: white; border: none; border-radius: 5px;">Add Mineral</button>
            </div>
        </div>
    </form>
</div>

<!-- Minerals List Table -->
<h3>Existing Minerals</h3>
<table style="width: 100%; border-collapse: collapse;">
    <thead>
        <tr style="background: #2c3e50; color: white;">
            <th style="padding: 10px; text-align: left;">ID</th>
            <th style="padding: 10px; text-align: left;">Mineral Type</th>
            <th style="padding: 10px; text-align: left;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.MineralsList != null && Model.MineralsList.Any())
        {
            @foreach (var mineral in Model.MineralsList)
            {
                <tr style="border-bottom: 1px solid #ddd;">
                    <td style="padding: 10px;">@mineral.Minls_code</td>
                    <td style="padding: 10px;">@mineral.Type</td>
                    <td style="padding: 10px;">
                        <form method="post" asp-page-handler="Delete" style="display: inline;">
                            <input type="hidden" name="id" value="@mineral.Minls_code" />
                            <button type="submit" style="background: #dc3545; color: white; border: none; padding: 5px 10px; border-radius: 3px; cursor: pointer;">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="3" style="padding: 20px; text-align: center;">No minerals found.</td>
            </tr>
        }
    </tbody>
</table>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div style="margin-top: 20px; padding: 10px; background: @(Model.Message.Contains("success") ? "#d4edda" : "#f8d7da"); color: @(Model.Message.Contains("success") ? "#155724" : "#721c24"); border-radius: 5px;">
        @Model.Message
    </div>
}