@page
@model SkyMineralsModern.Pages.StaffModel
@{
    ViewData["Title"] = "Staff Management";
    
    var role = HttpContext.Session.GetString("Role");
    if (role != "Administrator")
    {
        HttpContext.Response.Redirect("/Login");
    }
}

<h1>Staff Management</h1>
<hr />

<div style="background: #f4f4f4; padding: 20px; margin-bottom: 30px;">
    <h3>Add New Staff</h3>
    <form method="post">
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px;">
            <div><label>First Name:</label><input type="text" asp-for="NewStaff.Fname" style="width: 100%;" /></div>
            <div><label>Last Name:</label><input type="text" asp-for="NewStaff.Lname" style="width: 100%;" /></div>
            <div><label>Email:</label><input type="email" asp-for="NewStaff.Email" style="width: 100%;" /></div>
            <div><label>Phone:</label><input type="text" asp-for="NewStaff.Phone" style="width: 100%;" /></div>
            <div><label>Sex:</label><select asp-for="NewStaff.Sex" style="width: 100%;"><option>Male</option><option>Female</option></select></div>
            <div><label>Username:</label><input type="text" asp-for="NewStaff.Username" style="width: 100%;" /></div>
            <div><label>Password:</label><input type="password" asp-for="NewStaff.Password" style="width: 100%;" /></div>
            <div><label>Role:</label><select asp-for="NewStaff.Role" style="width: 100%;"><option>Administrator</option><option>Manager</option><option>Seller</option><option>Production</option></select></div>
        </div>
        <button type="submit" style="background: #28a745; color: white; padding: 8px 15px; border: none;">Add Staff</button>
    </form>
</div>

<h3>Existing Staff</h3>
<table style="width: 100%; border-collapse: collapse;">
    <thead><tr style="background: #465c71; color: white;"><th>ID</th><th>Name</th><th>Email</th><th>Phone</th><th>Username</th><th>Role</th><th>Actions</th></tr></thead>
    <tbody>
        @foreach (var staff in Model.StaffList)
        {
            <tr><td>@staff.Staff_id</td><td>@staff.Fname @staff.Lname</td><td>@staff.Email</td><td>@staff.Phone</td><td>@staff.Username</td><td>@staff.Role</td>
            <td><form method="post" asp-page-handler="Delete"><input type="hidden" name="id" value="@staff.Staff_id" /><button type="submit" style="background: #dc3545; color: white; border: none; padding: 5px 10px;">Delete</button></form></td></tr>
        }
    </tbody>
</table>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div style="background: #d4edda; color: #155724; padding: 10px; margin-top: 15px;">@Model.Message</div>
}