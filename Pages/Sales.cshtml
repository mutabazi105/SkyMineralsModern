@page
@model SkyMineralsModern.Pages.SalesModel
@{
    ViewData["Title"] = "Sales Management";
    
    var role = HttpContext.Session.GetString("Role");
    if (role != "Administrator" && role != "Seller")
    {
        HttpContext.Response.Redirect("/Login");
    }
}

<h1>Sales Management</h1>
<hr />

<div style="background: #f4f4f4; padding: 20px; margin-bottom: 30px;">
    <h3>Record New Sale</h3>
    <form method="post">
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px;">
            <div><label>Mineral:</label><select asp-for="NewSale.Minls_code" style="width: 100%;"><option value="">Select</option>@foreach (var m in Model.MineralsList){<option value="@m.Minls_code">@m.Type</option>}</select></div>
            <div><label>Quantity (kg):</label><input type="number" step="0.01" asp-for="NewSale.Quantity_sold" style="width: 100%;" /></div>
            <div><label>Grade (%):</label><input type="number" step="0.01" asp-for="NewSale.Tantale" style="width: 100%;" /></div>
            <div><label>Counter:</label><select asp-for="NewSale.Counter_code" style="width: 100%;"><option value="">Select</option>@foreach (var c in Model.CountersList){<option value="@c.Counter_code">@c.Name</option>}</select></div>
        </div>
        <button type="submit" style="background: #28a745; color: white; padding: 8px 15px; border: none;">Record Sale</button>
    </form>
</div>

<h3>Recent Sales</h3>
<table style="width: 100%; border-collapse: collapse;">
    <thead><tr style="background: #465c71; color: white;"><th>ID</th><th>Mineral</th><th>Quantity</th><th>Grade</th><th>Counter</th><th>Date</th></tr></thead>
    <tbody>
        @foreach (var sale in Model.SalesList)
        {
            <tr><td>@sale.Sales_id</td><td>@sale.MineralType</td><td>@sale.Quantity_sold</td><td>@sale.Tantale</td><td>@sale.CounterName</td><td>@sale.Sales_date.ToString("yyyy-MM-dd")</td></tr>
        }
    </tbody>
</table>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div style="background: #d4edda; color: #155724; padding: 10px; margin-top: 15px;">@Model.Message</div>
}