@page
@model SkyMineralsModern.Pages.TaggedModel
@{
    ViewData["Title"] = "Tagged Minerals";
    
    var role = HttpContext.Session.GetString("Role");
    if (role != "Administrator")
    {
        HttpContext.Response.Redirect("/Login");
    }
}

<h1>Tagged Minerals</h1>
<hr />

<div style="background: #f4f4f4; padding: 20px; margin-bottom: 30px;">
    <h3>Tag New Mineral</h3>
    <form method="post">
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px;">
            <div><label>Tag Number:</label><input type="text" asp-for="NewTag.Tag_number" style="width: 100%;" /></div>
            <div><label>Quantity (kg):</label><input type="number" step="0.01" asp-for="NewTag.Quantity_tagged" style="width: 100%;" /></div>
        </div>
        <button type="submit" style="background: #28a745; color: white; padding: 8px 15px; border: none;">Add Tag</button>
    </form>
</div>

<h3>Tagged Minerals List</h3>
<table style="width: 100%; border-collapse: collapse;">
    <thead><tr style="background: #465c71; color: white;"><th>Tag ID</th><th>Tag Number</th><th>Quantity</th><th>Date</th><th>Status</th></tr></thead>
    <tbody>
        @foreach (var tag in Model.TagsList)
        {
            <tr><td>@tag.Tag_id</td><td>@tag.Tag_number</td><td>@tag.Quantity_tagged</td><td>@tag.Tag_date.ToString("yyyy-MM-dd")</td><td>@tag.Status</td></tr>
        }
    </tbody>
</table>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div style="background: #d4edda; color: #155724; padding: 10px; margin-top: 15px;">@Model.Message</div>
}