@page
@model SkyMineralsModern.Pages.ReportsModel
@{
    ViewData["Title"] = "Reports Dashboard";
    
    var role = HttpContext.Session.GetString("Role");
    if (role != "Administrator" && role != "Manager")
    {
        HttpContext.Response.Redirect("/Login");
    }
}

<h1>Reports Dashboard</h1>
<hr />

<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 30px;">
    <div style="background: #4b6c9e; color: white; padding: 20px; text-align: center;">
        <h3>Total Sales</h3>
        <p style="font-size: 32px;">@Model.TotalQuantity.ToString("N2") kg</p>
    </div>
    <div style="background: #465c71; color: white; padding: 20px; text-align: center;">
        <h3>Total Production</h3>
        <p style="font-size: 32px;">@Model.TotalProduction.ToString("N2") kg</p>
    </div>
</div>

<div style="background: #f4f4f4; padding: 20px; margin-bottom: 30px;">
    <form method="get">
        <label>Start Date:</label>
        <input type="date" name="startDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
        <label>End Date:</label>
        <input type="date" name="endDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
        <button type="submit">Filter</button>
    </form>
</div>

<h3>Recent Sales</h3>
<table style="width: 100%; border-collapse: collapse;">
    <thead>
        <tr style="background: #465c71; color: white;">
            <th style="padding: 8px;">Date</th>
            <th style="padding: 8px;">Mineral</th>
            <th style="padding: 8px;">Quantity</th>
            <th style="padding: 8px;">Counter</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var sale in Model.RecentSales)
        {
            <tr>
                <td style="padding: 8px;">@sale.Sales_date.ToString("yyyy-MM-dd")</td>
                <td style="padding: 8px;">@sale.MineralType</td>
                <td style="padding: 8px;">@sale.Quantity_sold</td>
                <td style="padding: 8px;">@sale.CounterName</td>
            </tr>
        }
    </tbody>
</table>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div style="background: #d4edda; color: #155724; padding: 10px; margin-top: 15px;">@Model.Message</div>
}