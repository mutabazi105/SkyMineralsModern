@page
@model SkyMineralsModern.Pages.ReportsModel
@{
    ViewData["Title"] = "Reports Dashboard";
    
    var role = HttpContext.Session.GetString("Role");
    if (role != "Administrator" && role != "Manager")
    {
        HttpContext.Response.Redirect("/Login");
    }
}

<h1 style="color: #2c3e50;">Reports Dashboard</h1>
<hr />

<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 30px;">
    <!-- Sales Summary Card -->
    <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; border-radius: 10px;">
        <h3>💰 Total Sales</h3>
        <p style="font-size: 32px; margin: 10px 0;">@Model.TotalQuantity.ToString("N2") kg</p>
        <p>Total value: @Model.TotalValue.ToString("N0") Frw</p>
    </div>
    
    <!-- Production Summary Card -->
    <div style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; padding: 20px; border-radius: 10px;">
        <h3>⛏️ Total Production</h3>
        <p style="font-size: 32px; margin: 10px 0;">@Model.TotalProduction.ToString("N2") kg</p>
        <p>From @Model.ProductionCount records</p>
    </div>
</div>

<!-- Report Filters -->
<div style="background: #f4f4f4; padding: 20px; margin-bottom: 30px; border-radius: 8px;">
    <h3>Filter Reports</h3>
    <form method="get">
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px;">
            <div>
                <label>Start Date:</label>
                <input type="date" name="startDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" style="width: 100%; padding: 8px;" />
            </div>
            <div>
                <label>End Date:</label>
                <input type="date" name="endDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" style="width: 100%; padding: 8px;" />
            </div>
            <div>
                <label>&nbsp;</label>
                <button type="submit" style="width: 100%; padding: 8px; background: #006699; color: white; border: none; border-radius: 5px;">Apply Filter</button>
            </div>
        </div>
    </form>
</div>

<!-- Sales by Mineral Chart -->
<div style="margin-bottom: 30px;">
    <h3>Sales by Mineral Type</h3>
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="background: #2c3e50; color: white;">
                <th style="padding: 10px;">Mineral Type</th>
                <th style="padding: 10px;">Total Quantity (kg)</th>
                <th style="padding: 10px;">Percentage</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.SalesByMineral)
            {
                <tr style="border-bottom: 1px solid #ddd;">
                    <td style="padding: 10px;">@item.MineralType</td>
                    <td style="padding: 10px;">@item.Quantity.ToString("N2")</td>
                    <td style="padding: 10px;">
                        <div style="background: #e0e0e0; border-radius: 5px; height: 20px; width: 200px;">
                            <div style="background: #28a745; width: @((Model.TotalQuantity > 0 ? item.Quantity / Model.TotalQuantity * 100 : 0))%; height: 20px; border-radius: 5px; text-align: center; color: white; font-size: 12px;">
                                @((Model.TotalQuantity > 0 ? (item.Quantity / Model.TotalQuantity * 100).ToString("N1") : "0"))%
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Recent Sales -->
<div style="margin-bottom: 30px;">
    <h3>Recent Sales (Last 10)</h3>
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="background: #2c3e50; color: white;">
                <th style="padding: 10px;">Date</th>
                <th style="padding: 10px;">Mineral</th>
                <th style="padding: 10px;">Quantity (kg)</th>
                <th style="padding: 10px;">Counter</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sale in Model.RecentSales)
            {
                <tr style="border-bottom: 1px solid #ddd;">
                    <td style="padding: 10px;">@sale.Sales_date.ToString("yyyy-MM-dd")</td>
                    <td style="padding: 10px;">@sale.MineralType</td>
                    <td style="padding: 10px;">@sale.Quantity_sold.ToString("N2")</td>
                    <td style="padding: 10px;">@sale.CounterName</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Recent Production -->
<div style="margin-bottom: 30px;">
    <h3>Recent Production (Last 10)</h3>
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="background: #2c3e50; color: white;">
                <th style="padding: 10px;">Date</th>
                <th style="padding: 10px;">Mineral</th>
                <th style="padding: 10px;">Quantity (kg)</th>
                <th style="padding: 10px;">Staff</th>
             </tr>
        </thead>
        <tbody>
            @foreach (var prod in Model.RecentProduction)
            {
                <tr style="border-bottom: 1px solid #ddd;">
                    <td style="padding: 10px;">@prod.Issue_date.ToString("yyyy-MM-dd")</td>
                    <td style="padding: 10px;">@prod.MineralType</td>
                    <td style="padding: 10px;">@prod.Quantity_mined.ToString("N2")</td>
                    <td style="padding: 10px;">@prod.StaffName</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div style="margin-top: 20px; padding: 10px; background: #f8d7da; color: #721c24; border-radius: 5px;">
        @Model.Message
    </div>
}