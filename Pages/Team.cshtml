@page
@model SkyMineralsModern.Pages.TeamModel
@{
    ViewData["Title"] = "Team Management";
    
    var role = HttpContext.Session.GetString("Role");
    if (role != "Administrator")
    {
        HttpContext.Response.Redirect("/Login");
    }
}

<h1 style="color: #2c3e50;">Team Management</h1>
<hr />

<!-- Add New Team Form -->
<div style="background: #f4f4f4; padding: 20px; margin-bottom: 30px; border-radius: 8px;">
    <h3>Create New Team</h3>
    <form method="post">
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px;">
            <div>
                <label>Team Name:</label>
                <input type="text" asp-for="NewTeam.Team_Name" style="width: 100%; padding: 8px;" required />
            </div>
            <div>
                <label>Team Leader (Staff):</label>
                <select asp-for="NewTeam.Staff_id" style="width: 100%; padding: 8px;" required>
                    <option value="">Select Team Leader</option>
                    @foreach (var staff in Model.StaffList)
                    {
                        <option value="@staff.Staff_id">@staff.Fname @staff.Lname</option>
                    }
                </select>
            </div>
        </div>
        <button type="submit" style="margin-top: 15px; padding: 10px 20px; background: #28a745; color: white; border: none; border-radius: 5px;">Create Team</button>
    </form>
</div>

<!-- Teams List -->
<h3>Existing Teams</h3>
<table style="width: 100%; border-collapse: collapse;">
    <thead>
        <tr style="background: #2c3e50; color: white;">
            <th style="padding: 10px;">Team ID</th>
            <th style="padding: 10px;">Team Name</th>
            <th style="padding: 10px;">Team Leader</th>
            <th style="padding: 10px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.TeamsList != null && Model.TeamsList.Any())
        {
            @foreach (var team in Model.TeamsList)
            {
                <tr style="border-bottom: 1px solid #ddd;">
                    <td style="padding: 10px;">@team.Team_id</td>
                    <td style="padding: 10px;">@team.Team_Name</td>
                    <td style="padding: 10px;">@team.LeaderName</td>
                    <td style="padding: 10px;">
                        <form method="post" asp-page-handler="Delete" style="display: inline;">
                            <input type="hidden" name="id" value="@team.Team_id" />
                            <button type="submit" style="background: #dc3545; color: white; border: none; padding: 5px 10px; border-radius: 3px; cursor: pointer;">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" style="padding: 20px; text-align: center;">No teams found.</td>
            </tr>
        }
    </tbody>
</table>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div style="margin-top: 20px; padding: 10px; background: @(Model.Message.Contains("success") ? "#d4edda" : "#f8d7da"); color: @(Model.Message.Contains("success") ? "#155724" : "#721c24"); border-radius: 5px;">
        @Model.Message
    </div>
}