@page
@model SkyMineralsModern.Pages.TeamModel
@{
    ViewData["Title"] = "Team Management";
    
    var role = HttpContext.Session.GetString("Role");
    if (role != "Administrator")
    {
        HttpContext.Response.Redirect("/Login");
    }
}

<h1>Team Management</h1>
<hr />

<div style="background: #f4f4f4; padding: 20px; margin-bottom: 30px;">
    <h3>Create New Team</h3>
    <form method="post">
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px;">
            <div><label>Team Name:</label><input type="text" asp-for="NewTeam.Team_Name" style="width: 100%;" /></div>
            <div><label>Team Leader:</label><select asp-for="NewTeam.Staff_id" style="width: 100%;"><option value="">Select</option>@foreach (var s in Model.StaffList){<option value="@s.Staff_id">@s.Fname @s.Lname</option>}</select></div>
        </div>
        <button type="submit" style="background: #28a745; color: white; padding: 8px 15px; border: none;">Create Team</button>
    </form>
</div>

<h3>Existing Teams</h3>
<table style="width: 100%; border-collapse: collapse;">
    <thead><tr style="background: #465c71; color: white;"><th>Team ID</th><th>Team Name</th><th>Team Leader</th><th>Actions</th></tr></thead>
    <tbody>
        @foreach (var team in Model.TeamsList)
        {
            <tr><td>@team.Team_id</td><td>@team.Team_Name</td><td>@team.LeaderName</td>
            <td><form method="post" asp-page-handler="Delete"><input type="hidden" name="id" value="@team.Team_id" /><button type="submit" style="background: #dc3545; color: white; border: none; padding: 5px 10px;">Delete</button></form></td></tr>
        }
    </tbody>
</table>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div style="background: #d4edda; color: #155724; padding: 10px; margin-top: 15px;">@Model.Message</div>
}