@page
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "ADMIN-START";
    
    var role = HttpContext.Session.GetString("Role");
    if (role != "Administrator")
    {
        HttpContext.Response.Redirect("/Login");
    }
}

<!DOCTYPE html>
<html>
<head>
    <title>SKY Minerals - Admin Dashboard</title>
    <style type="text/css">
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f4f4f4;
        }
        .header {
            background-color: #003366;
            color: white;
            padding: 15px;
        }
        .menu {
            background-color: #006699;
            padding: 10px;
        }
        .menu a {
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            margin-right: 10px;
            display: inline-block;
        }
        .menu a:hover {
            background-color: #009999;
        }
        .container {
            display: flex;
            padding: 20px;
            min-height: 500px;
        }
        .sidebar {
            width: 250px;
            background-color: #f8f9fa;
            padding: 15px;
            border-radius: 5px;
            margin-right: 20px;
        }
        .content {
            flex: 1;
            background-color: white;
            padding: 20px;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        .footer {
            background-color: #2c3e50;
            color: white;
            text-align: center;
            padding: 15px;
            margin-top: 20px;
        }
        .card {
            background: #f8f9fa;
            padding: 20px;
            margin-bottom: 20px;
            border-radius: 5px;
            text-align: center;
            cursor: pointer;
            transition: transform 0.2s;
        }
        .card:hover {
            transform: translateY(-5px);
            background: #e9ecef;
        }
        .card h3 {
            margin: 0;
            color: #003366;
        }
        .card p {
            color: #666;
            margin: 10px 0 0;
        }
        .btn {
            display: inline-block;
            padding: 10px 20px;
            background-color: #006699;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }
        .btn:hover {
            background-color: #009999;
        }
    </style>
</head>
<body>

<div class="header">
    <h1>SKY Minerals Management Information System</h1>
</div>

<div class="menu">
    <a href="/Homeadmin">🏠 HOME</a>
    <a href="/Staff">👥 STAFF</a>
    <a href="/Minerals">⛏️ MINERALS</a>
    <a href="/Tagged">🏷️ TAGGED</a>
    <a href="/Sales">💰 SALES</a>
    <a href="/Production">📦 PRODUCTION</a>
    <a href="/Team">👥 TEAM</a>
    <a href="/Reports">📊 REPORT</a>
    <a href="/Login" style="float: right;">🚪 LOGOUT</a>
</div>

<div class="container">
    <div class="sidebar">
        <h3 style="color: #003366;">ABOUT SKY MINERALS LTD</h3>
        <p><a href="#" style="color: #006699;">Background</a></p>
        <p><a href="#" style="color: #006699;">Mission and Vision</a></p>
        <p><a href="#" style="color: #006699;">About Us</a></p>
        
        <hr />
        
        <h3 style="color: #003366;">COMPANY ACTIVITIES</h3>
        <p><a href="/Minerals" style="color: #006699;">Minerals</a></p>
        
        <hr />
        
        <h3 style="color: #003366;">COMPANY PERIMETER MAP</h3>
        <p><a href="#" style="color: #006699;">Maps</a></p>
        <p><a href="#" style="color: #006699;">Perimeter Specification</a></p>
    </div>
    
    <div class="content">
        <h2 style="color: #003366;">Welcome to Admin Dashboard</h2>
        <p>Select an option from the menu to manage your SKYminerals operations.</p>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 30px;">
            <div class="card" onclick="location.href='/Staff'">
                <h3>👥 STAFF</h3>
                <p>Manage staff members</p>
            </div>
            <div class="card" onclick="location.href='/Minerals'">
                <h3>⛏️ MINERALS</h3>
                <p>Manage minerals</p>
            </div>
            <div class="card" onclick="location.href='/Tagged'">
                <h3>🏷️ TAGGED</h3>
                <p>Manage tagged minerals</p>
            </div>
            <div class="card" onclick="location.href='/Sales'">
                <h3>💰 SALES</h3>
                <p>Manage sales</p>
            </div>
            <div class="card" onclick="location.href='/Production'">
                <h3>📦 PRODUCTION</h3>
                <p>Track production</p>
            </div>
            <div class="card" onclick="location.href='/Team'">
                <h3>👥 TEAM</h3>
                <p>Manage teams</p>
            </div>
            <div class="card" onclick="location.href='/Reports'">
                <h3>📊 REPORTS</h3>
                <p>View reports</p>
            </div>
        </div>
    </div>
</div>

<div class="footer">
    Copyright © 2015-2026 Sky Minerals Ltd - All Rights Reserved
</div>

</body>
</html>