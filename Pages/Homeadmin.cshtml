@page
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "ADMIN-START";
    
    var role = HttpContext.Session.GetString("Role");
    if (role != "Administrator")
    {
        HttpContext.Response.Redirect("/Login");
    }
}

<!-- Main Admin Dashboard Content -->
<table style="width: 100%; border-collapse: collapse;">
    <tr>
        <td style="width: 70%; vertical-align: top;">
            <img src="/Photos/image-2.jpg" style="width: 100%;" alt="SKY Minerals" />
        </td>
        <td style="width: 30%; vertical-align: top; background-color: #003366; padding: 10px;">
            <div>
                <a href="/Staff" style="color: white; text-decoration: none; display: block; padding: 8px; font-weight: bold;">👥 STAFF</a>
                <a href="/Minerals" style="color: white; text-decoration: none; display: block; padding: 8px; font-weight: bold;">⛏️ MINERALS</a>
                <a href="/Tagged" style="color: white; text-decoration: none; display: block; padding: 8px; font-weight: bold;">🏷️ TAGGED</a>
                <a href="/Sales" style="color: white; text-decoration: none; display: block; padding: 8px; font-weight: bold;">💰 SALES</a>
                <a href="/Production" style="color: white; text-decoration: none; display: block; padding: 8px; font-weight: bold;">📦 PRODUCTION</a>
                <a href="/Team" style="color: white; text-decoration: none; display: block; padding: 8px; font-weight: bold;">👥 TEAM</a>
                <a href="/Reports" style="color: white; text-decoration: none; display: block; padding: 8px; font-weight: bold;">📊 REPORT</a>
            </div>
        </td>
    </tr>
</table>

<p>&nbsp;</p>

<!-- About Section -->
